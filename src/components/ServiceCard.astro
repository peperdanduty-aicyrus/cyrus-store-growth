---
import type { Service } from '@data/services';

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article class="card flex h-full flex-col">
  <h3 class="text-lg font-bold text-ink">{service.title}</h3>
  <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{service.summary}</p>
  <ul class="mt-5 flex flex-wrap gap-2" aria-label={`${service.title}包含内容`}>
    {
      service.points.map((point) => (
        <li class="rounded-full bg-cloud px-3 py-1 text-xs font-medium text-pine">{point}</li>
      ))
    }
  </ul>
  <p class="mt-5 border-t border-line pt-4 text-sm leading-6 text-slate-500">{service.fit}</p>
</article>
