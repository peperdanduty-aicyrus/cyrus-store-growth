---
import PrimaryButton from './PrimaryButton.astro';
import { serviceMatrix } from '@data/consulting';
---

<section class="section-pad">
  <div class="container-narrow">
    <div class="mx-auto mb-8 max-w-3xl text-center">
      <p class="eyebrow mb-3">服务矩阵</p>
      <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">从一次诊断，到一套可执行的线上增长方案</h2>
    </div>
    <div class="grid gap-5 lg:grid-cols-4">
      {
        serviceMatrix.map((service) => (
          <article class="flex h-full flex-col rounded-lg border border-line bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold text-moss">{service.label}</p>
            <h3 class="mt-3 text-xl font-bold text-ink">{service.title}</h3>
            <p class="mt-3 text-sm font-semibold leading-6 text-slate-700">{service.position}</p>
            <div class="mt-5 space-y-4 text-sm leading-7 text-slate-600">
              <p><span class="font-semibold text-ink">适合：</span>{service.fit}</p>
              <p><span class="font-semibold text-ink">交付：</span>{service.deliverable}</p>
            </div>
            <div class="mt-6">
              <PrimaryButton href={service.href} variant="secondary">{service.cta}</PrimaryButton>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
