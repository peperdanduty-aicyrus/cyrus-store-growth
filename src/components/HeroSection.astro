---
import PrimaryButton from './PrimaryButton.astro';
import { acquisitionLinks } from '@data/consulting';
import { site } from '@data/site';
---

<section class="bg-ink section-pad text-white">
  <div class="container-narrow grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <p class="text-sm font-semibold text-emerald-200">{site.subBrand} / 本地门店线上获客诊断</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight tracking-normal sm:text-5xl lg:text-6xl">
        本地门店线上增长，不是多发内容，而是先看清漏客点
      </h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-slate-300 sm:text-lg">
        我帮助中医馆、推拿馆、口腔、宠物医院、社区医美、综合门诊等本地门店，拆解美团点评、小红书、朋友圈、视频号和本地搜索中的真实问题，找到影响曝光、咨询和到店转化的关键环节。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <PrimaryButton href="/contact">预约一次门店诊断</PrimaryButton>
        <PrimaryButton href="/methodology" variant="secondaryDark">查看我的诊断框架</PrimaryButton>
      </div>
    </div>

    <aside class="rounded-xl border border-white/10 bg-white/[0.06] p-5 shadow-soft sm:p-6">
      <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-4">
        <div>
          <p class="text-xs font-semibold text-emerald-200">Local Growth Map</p>
          <h2 class="mt-2 text-2xl font-bold">门店线上获客链路图</h2>
        </div>
        <span class="rounded-full border border-emerald-200/40 px-3 py-1 text-xs font-semibold text-emerald-100">诊断视角</span>
      </div>
      <div class="mt-5 grid gap-3">
        {
          acquisitionLinks.map((link, index) => (
            <div class="rounded-lg border border-white/10 bg-white/[0.07] p-4">
              <div class="flex items-center gap-3">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-300/15 text-sm font-bold text-emerald-100">
                  {index + 1}
                </span>
                <p class="font-semibold text-white">{link.title}</p>
              </div>
              <p class="mt-3 text-sm leading-7 text-slate-300">{link.items.join(' / ')}</p>
            </div>
          ))
        }
      </div>
    </aside>
  </div>
</section>
