---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto mb-8 max-w-3xl text-center sm:mb-10">
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="text-2xl font-bold tracking-normal text-ink sm:text-3xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-600">{description}</p>}
</div>
