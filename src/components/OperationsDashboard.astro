---
const channels = ['美团页面', '团单调整', '评价关键词', '小红书选题', '朋友圈文案', '数据复盘'];
const checklist = ['主图卖点', '项目梯度', '竞品对比', '搜索词', '承接话术'];
---

<div class="rounded-lg border border-line bg-ink p-4 text-white shadow-soft sm:p-5">
  <div class="flex items-center justify-between gap-3">
    <div>
      <p class="text-xs font-semibold text-emerald-200">门店线上代运营工作台</p>
      <h2 class="mt-2 text-xl font-bold tracking-normal">诊断、优化、内容、复盘一张表推进</h2>
    </div>
    <div class="rounded-md bg-white px-3 py-2 text-right text-xs font-semibold text-pine">
      <span class="block text-lg text-ink">69元</span>
      诊断报告
    </div>
  </div>

  <div class="mt-5 grid gap-3 sm:grid-cols-2">
    <div class="rounded-md bg-white/10 p-4">
      <p class="text-xs font-semibold text-emerald-200">平台动作</p>
      <div class="mt-3 grid grid-cols-2 gap-2">
        {
          channels.map((channel) => (
            <div class="rounded-md bg-white px-3 py-2 text-xs font-semibold text-ink">{channel}</div>
          ))
        }
      </div>
    </div>

    <div class="rounded-md bg-white p-4 text-ink">
      <div class="flex items-center justify-between gap-3">
        <p class="text-xs font-semibold text-pine">月度代运营</p>
        <span class="rounded-full bg-cloud px-2 py-1 text-[11px] font-semibold text-slate-600">每周6-8次</span>
      </div>
      <div class="mt-4 space-y-2">
        <div class="h-3 w-full rounded-full bg-cloud">
          <div class="h-3 w-4/5 rounded-full bg-pine"></div>
        </div>
        <div class="h-3 w-full rounded-full bg-cloud">
          <div class="h-3 w-2/3 rounded-full bg-moss"></div>
        </div>
        <div class="h-3 w-full rounded-full bg-cloud">
          <div class="h-3 w-3/4 rounded-full bg-ink"></div>
        </div>
      </div>
      <p class="mt-4 text-xs leading-5 text-slate-600">按周推进页面、内容、评价和数据复盘，店主能看到每一步在改什么。</p>
    </div>
  </div>

  <div class="mt-3 rounded-md bg-white p-4 text-ink">
    <div class="grid gap-3 sm:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-xs font-semibold text-pine">诊断目录</p>
        <ul class="mt-3 space-y-2">
          {
            checklist.map((item) => (
              <li class="flex items-center gap-2 text-xs text-slate-600">
                <span class="h-1.5 w-1.5 rounded-full bg-pine"></span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="rounded-md bg-cloud p-3">
        <p class="text-xs font-semibold text-ink">交付链路</p>
        <div class="mt-3 grid grid-cols-4 gap-2 text-center text-[11px] font-semibold text-slate-600">
          <span class="rounded bg-white px-2 py-2">诊断</span>
          <span class="rounded bg-white px-2 py-2">方案</span>
          <span class="rounded bg-white px-2 py-2">执行</span>
          <span class="rounded bg-white px-2 py-2">复盘</span>
        </div>
      </div>
    </div>
  </div>
</div>
