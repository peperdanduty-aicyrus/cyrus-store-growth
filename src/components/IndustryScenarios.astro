---
import { industryScenarios } from '@data/consulting';
---

<section class="bg-cloud section-pad">
  <div class="container-narrow">
    <div class="mx-auto mb-8 max-w-3xl text-center">
      <p class="eyebrow mb-3">行业场景</p>
      <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">我重点关注这些本地门店场景</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        industryScenarios.map((industry) => (
          <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
            <h3 class="text-xl font-bold text-ink">{industry.title}</h3>
            <p class="mt-4 text-sm leading-7 text-slate-600"><span class="font-semibold text-ink">核心问题：</span>{industry.problem}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600"><span class="font-semibold text-ink">解决方向：</span>{industry.solution}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
