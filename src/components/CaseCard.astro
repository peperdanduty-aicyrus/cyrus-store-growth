---
import type { CaseItem } from '@data/cases';

interface Props {
  item: CaseItem;
}

const { item } = Astro.props;
---

<article class="card h-full">
  <p class="text-xs font-semibold text-moss">{item.industry}</p>
  <h3 class="mt-2 text-lg font-bold text-ink">{item.title}</h3>
  <dl class="mt-5 space-y-4 text-sm leading-6">
    <div>
      <dt class="font-semibold text-ink">问题</dt>
      <dd class="mt-1 text-slate-600">{item.problem}</dd>
    </div>
    <div>
      <dt class="font-semibold text-ink">解决方案</dt>
      <dd class="mt-1 text-slate-600">{item.solution}</dd>
    </div>
    <div>
      <dt class="font-semibold text-ink">结果/目标</dt>
      <dd class="mt-1 text-slate-600">{item.result}</dd>
    </div>
  </dl>
  <a href="/contact" class="mt-6 inline-flex text-sm font-semibold text-pine hover:text-ink">查看详情</a>
</article>
