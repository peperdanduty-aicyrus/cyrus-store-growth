---
import type { CaseItem, CaseMedia } from '@data/cases';

interface Props {
  item: CaseItem;
  variant?: 'summary' | 'detail';
}

const { item, variant = 'summary' } = Astro.props;
const firstMedia = item.stages.flatMap((stage) => stage.media)[0];
const firstImage = (media: CaseMedia) => media.type === 'report' ? media.cover : media.src;
const stageId = (caseId: string, index: number) => `${caseId}-stage-${index + 1}`;
---

{
  variant === 'summary' ? (
    <article class="group overflow-hidden rounded-lg border border-line bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft">
      {firstMedia && (
        <div class="relative overflow-hidden bg-cloud">
          <img
            src={firstImage(firstMedia)}
            alt={firstMedia.title}
            class="aspect-[16/10] w-full object-cover object-top transition duration-500 group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute left-3 top-3 rounded-full bg-white/95 px-3 py-1 text-xs font-semibold text-pine shadow-sm">
            {item.category}
          </div>
        </div>
      )}
      <div class="p-5">
        <p class="text-xs font-semibold text-moss">{item.industry}</p>
        <h3 class="mt-2 text-lg font-bold leading-snug text-ink">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">{item.highlight}</p>
        <div class="mt-5 flex items-center justify-between border-t border-line pt-4">
          <span class="text-xs font-semibold text-slate-500">方案预览</span>
          <a href="/cases" class="text-sm font-semibold text-pine hover:text-ink">查看详情</a>
        </div>
      </div>
    </article>
  ) : (
    <article id={item.id} class="case-card scroll-mt-24 rounded-xl border border-line bg-white shadow-sm" data-case-card data-category={item.category}>
      <div class="grid gap-0 lg:grid-cols-[0.36fr_0.64fr]">
        <aside class="border-b border-line bg-ink p-5 text-white lg:sticky lg:top-20 lg:self-start lg:border-b-0 lg:border-r lg:p-7">
          <p class="text-xs font-semibold text-emerald-200">{item.category} / {item.industry}</p>
          <h2 class="mt-3 text-2xl font-bold leading-tight">{item.title}</h2>
          <p class="mt-4 text-sm leading-7 text-slate-300">{item.summary}</p>
          <dl class="mt-5 grid gap-3 text-xs leading-6 text-slate-300">
            <div>
              <dt class="font-semibold text-white">门店阶段</dt>
              <dd class="mt-1">{item.storeStage}</dd>
            </div>
            <div>
              <dt class="font-semibold text-white">核心问题</dt>
              <dd class="mt-1">{item.coreProblem}</dd>
            </div>
            <div>
              <dt class="font-semibold text-white">诊断框架</dt>
              <dd class="mt-1">{item.framework}</dd>
            </div>
          </dl>

          <div class="mt-6 rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-white">交付清单</p>
            <ul class="mt-3 space-y-2">
              {item.deliverables.map((deliverable) => (
                <li class="flex gap-2 text-sm leading-6 text-slate-300">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-300"></span>
                  <span>{deliverable}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-6 grid gap-2">
            {item.stages.map((stage, index) => (
              <a
                href={`#${stageId(item.id, index)}`}
                class="rounded-md border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-slate-200 hover:bg-white hover:text-ink"
              >
                {index + 1}. {stage.label}
              </a>
            ))}
          </div>

          <p class="mt-6 text-xs leading-6 text-slate-400">
            <span class="font-semibold text-slate-200">可复用经验：</span>{item.reusable}
          </p>
        </aside>

        <div class="space-y-6 p-5 sm:p-7">
          {item.stages.map((stage, index) => (
            <section id={stageId(item.id, index)} class="scroll-mt-24 rounded-lg border border-line bg-cloud p-4 sm:p-5">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold text-pine">{stage.label}</p>
                  <h3 class="mt-1 text-xl font-bold leading-snug text-ink">{stage.title}</h3>
                </div>
                <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-500">0{index + 1}</span>
              </div>
              <p class="mt-3 text-sm leading-7 text-slate-600">{stage.description}</p>
              <div class="mt-4 rounded-md border border-line bg-white p-4 text-sm leading-7 text-slate-700">
                <span class="font-semibold text-ink">运营判断：</span>{stage.insight}
              </div>

              <div class="mt-5 grid gap-4">
                {stage.media.map((media) => (
                  media.type === 'report' ? (
                    <figure class="rounded-lg border border-line bg-white p-3 shadow-sm">
                      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line pb-3">
                        <div>
                          <p class="text-sm font-bold text-ink">{media.title}</p>
                          <p class="mt-1 text-xs leading-5 text-slate-500">{media.caption}</p>
                        </div>
                        <span class="rounded-full bg-cloud px-3 py-1 text-xs font-semibold text-pine">线上预览</span>
                      </div>
                      <div class="mt-3 max-h-[34rem] space-y-3 overflow-y-auto rounded-md bg-slate-100 p-3">
                        {media.pages.map((page, pageIndex) => (
                          <button
                            type="button"
                            class="block w-full cursor-zoom-in overflow-hidden rounded-md border border-line bg-white shadow-sm"
                            data-lightbox-src={page}
                            data-lightbox-title={`${media.title} 第${pageIndex + 1}页`}
                            aria-label={`放大查看${media.title}第${pageIndex + 1}页`}
                          >
                            <img src={page} alt={`${media.title} 第${pageIndex + 1}页`} class="w-full object-contain" loading="lazy" />
                          </button>
                        ))}
                      </div>
                    </figure>
                  ) : (
                    <figure class="rounded-lg border border-line bg-white p-3 shadow-sm">
                      <button
                        type="button"
                        class="block max-h-[30rem] w-full cursor-zoom-in overflow-hidden rounded-md bg-slate-100"
                        data-lightbox-src={media.src}
                        data-lightbox-title={media.title}
                        aria-label={`放大查看${media.title}`}
                      >
                        <img src={media.src} alt={media.title} class="w-full object-cover object-top" loading="lazy" />
                      </button>
                      <figcaption class="pt-3">
                        <p class="text-sm font-bold text-ink">{media.title}</p>
                        <p class="mt-1 text-xs leading-5 text-slate-500">{media.caption}</p>
                      </figcaption>
                    </figure>
                  )
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </article>
  )
}
