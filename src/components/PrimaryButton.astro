---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'secondaryDark';
}

const { href, variant = 'primary' } = Astro.props;
const classes =
  variant === 'primary'
    ? 'bg-pine text-white hover:bg-ink'
    : variant === 'secondaryDark'
      ? 'border border-white/30 bg-transparent text-white hover:bg-white hover:text-ink'
      : 'border border-pine bg-white text-pine hover:bg-cloud';
---

<a
  href={href}
  class:list={[
    'inline-flex min-h-11 items-center justify-center rounded-md px-5 py-3 text-sm font-semibold shadow-sm',
    classes
  ]}
>
  <slot />
</a>
