---
import type { CaseEvidenceItem } from '@data/cases';

interface Props {
  evidence: CaseEvidenceItem;
}

const { evidence } = Astro.props;
---

<div class="rounded-lg border border-line bg-cloud p-3">
  <div class="rounded-md bg-white p-3 shadow-sm">
    <div class="flex items-center justify-between gap-3">
      <p class="text-xs font-semibold text-pine">{evidence.label}</p>
      <span class="rounded-full bg-cloud px-2 py-1 text-[11px] font-semibold text-slate-500">已匿名化</span>
    </div>
    <div class="mt-3 space-y-2">
      <div class="h-3 w-11/12 rounded-full bg-slate-200"></div>
      <div class="h-3 w-3/4 rounded-full bg-slate-200"></div>
      <div class="h-10 rounded-md bg-slate-100"></div>
    </div>
    <ul class="mt-3 space-y-2">
      {
        evidence.points.map((point) => (
          <li class="flex gap-2 text-xs leading-5 text-slate-600">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-moss"></span>
            <span>{point}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
