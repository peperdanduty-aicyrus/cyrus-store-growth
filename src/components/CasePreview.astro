---
import type { CaseItem } from '@data/cases';
import PrimaryButton from './PrimaryButton.astro';

interface Props {
  items: CaseItem[];
}

const { items } = Astro.props;
---

<section class="section-pad">
  <div class="container-narrow">
    <div class="mx-auto mb-8 max-w-3xl text-center">
      <p class="eyebrow mb-3">案例预览</p>
      <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">不是展示漂亮页面，而是展示问题如何被拆开</h2>
      <p class="mt-4 text-base leading-7 text-slate-600">案例默认匿名化，不公开客户隐私；没有稳定数据的地方，用阶段目标和优化重点表达。</p>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {
        items.map((item) => (
          <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold text-moss">{item.industry}</p>
            <h3 class="mt-3 text-xl font-bold text-ink">{item.title}</h3>
            <dl class="mt-5 grid gap-3 text-sm leading-6 text-slate-600">
              <div><dt class="font-semibold text-ink">原始问题</dt><dd class="mt-1">{item.summary}</dd></div>
              <div><dt class="font-semibold text-ink">诊断切入点</dt><dd class="mt-1">{item.highlight}</dd></div>
              <div><dt class="font-semibold text-ink">优化动作</dt><dd class="mt-1">{item.deliverables.slice(0, 3).join('、')}</dd></div>
              <div><dt class="font-semibold text-ink">阶段目标</dt><dd class="mt-1">{item.suitableFor}</dd></div>
            </dl>
            <div class="mt-5">
              <PrimaryButton href="/cases" variant="secondary">查看详情</PrimaryButton>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
