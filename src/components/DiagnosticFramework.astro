---
import PrimaryButton from './PrimaryButton.astro';
import { diagnosticModel } from '@data/consulting';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section id="diagnostic-framework" class:list={[compact ? 'section-pad' : 'bg-cloud section-pad']}>
  <div class="container-narrow">
    <div class="mb-8 grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="eyebrow">诊断方法论</p>
        <h2 class="mt-3 text-3xl font-bold leading-tight text-ink sm:text-4xl">
          我用一套 5 层诊断模型看门店线上获客
        </h2>
      </div>
      <div class="rounded-lg border border-line bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold text-pine">Local Growth 5D 诊断模型</p>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          先看定位，再看页面、搜索、内容和转化。不是直接判断“该发什么”，而是先找清楚顾客在哪一步流失。
        </p>
      </div>
    </div>

    <div class="grid gap-4 lg:grid-cols-5">
      {
        diagnosticModel.map((item) => (
          <article class="relative rounded-lg border border-line bg-white p-5 shadow-sm">
            <p class="text-3xl font-bold text-pine">{item.code}</p>
            <h3 class="mt-4 text-lg font-bold text-ink">{item.title}</h3>
            <p class="mt-3 text-sm font-semibold leading-6 text-slate-700">{item.question}</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
          </article>
        ))
      }
    </div>
    {!compact && (
      <div class="mt-8 text-center">
        <PrimaryButton href="/methodology" variant="secondary">查看完整方法论</PrimaryButton>
      </div>
    )}
  </div>
</section>
