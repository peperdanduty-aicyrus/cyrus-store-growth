---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  items: FAQ[];
  eyebrow?: string;
  title?: string;
  description?: string;
}

const { items, eyebrow = 'FAQ', title = '常见问题', description } = Astro.props;
---

<section class="section-pad">
  <div class="container-narrow">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow mb-3">{eyebrow}</p>
      <h2 class="text-3xl font-bold text-ink sm:text-4xl">{title}</h2>
      {description && <p class="mt-4 text-base leading-8 text-slate-600">{description}</p>}
      <div class="mt-8 divide-y divide-line rounded-lg border border-line bg-white shadow-sm">
        {
          items.map((item) => (
            <details class="group p-5">
              <summary class="cursor-pointer list-none text-base font-bold text-ink">
                {item.question}
              </summary>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
