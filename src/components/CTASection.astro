---
import PrimaryButton from './PrimaryButton.astro';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  cta?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = '下一步',
  title = '想知道你的门店线上哪里正在漏客？',
  description = '发送门店名称、所在城市、行业类型和美团/大众点评链接，我会先从页面、团单、评价、搜索和内容承接几个角度，帮你判断最优先需要修改的地方。',
  cta = '预约一次门店诊断',
  primaryHref = '/contact',
  primaryLabel = cta,
  secondaryHref,
  secondaryLabel
} = Astro.props;
---

<section class="section-pad">
  <div class="container-narrow rounded-xl bg-ink px-5 py-10 text-white shadow-soft sm:px-8 lg:px-12">
    <div class="grid items-center gap-8 lg:grid-cols-[1fr_auto]">
      <div>
        <p class="text-sm font-semibold text-emerald-200">{eyebrow}</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold leading-tight sm:text-4xl">{title}</h2>
        <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-300">{description}</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
        <PrimaryButton href={primaryHref}>{primaryLabel}</PrimaryButton>
        {
          secondaryHref && secondaryLabel && (
            <PrimaryButton href={secondaryHref} variant="secondaryDark">{secondaryLabel}</PrimaryButton>
          )
        }
      </div>
    </div>
  </div>
</section>
