---
import BaseLayout from '@layouts/BaseLayout.astro';
import ResourceCard from '@components/ResourceCard.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { resources } from '@data/resources';
---

<BaseLayout title="免费资料" description="中医馆、美团团单、小红书选题和朋友圈活动文案模板领取页面。">
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">免费资料</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">先用检查表做一次门店自查</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        资料适合店主自己先看基础问题。领取按钮暂时跳转联系页，添加微信后领取。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading title="可领取资料" description="围绕美团、小红书和私域活动的基础模板。" />
      <div class="grid gap-5 md:grid-cols-2">
        {resources.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </div>
  </section>
</BaseLayout>
