---
import BaseLayout from '@layouts/BaseLayout.astro';
import { site } from '@data/site';

const flow = ['发送门店信息', '初步诊断线上店铺/账号', '输出问题清单', '确认服务内容', '开始执行并定期复盘'];
---

<BaseLayout title="联系合作" description="添加微信或发送邮件，沟通本地门店线上运营诊断与合作。">
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">联系合作</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">把门店信息发来，先做初步判断</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        你可以先提供门店名称、城市商圈、行业、平台链接和当前最想解决的问题。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="space-y-5">
        <div class="card">
          <h2 class="text-xl font-bold text-ink">微信</h2>
          <div class="mt-4 flex aspect-square max-w-56 items-center justify-center rounded-lg border border-dashed border-moss bg-cloud text-center text-sm leading-6 text-slate-600">
            {site.wechat}
          </div>
          <p class="mt-4 text-sm text-slate-500">后续替换为真实二维码图片。</p>
        </div>
        <div class="card">
          <h2 class="text-xl font-bold text-ink">邮箱</h2>
          <p class="mt-3 text-sm text-slate-600">{site.email}</p>
        </div>
      </aside>

      <div class="space-y-6">
        <article class="card">
          <h2 class="text-xl font-bold text-ink">合作流程</h2>
          <ol class="mt-5 grid gap-3">
            {
              flow.map((item, index) => (
                <li class="flex gap-3 rounded-md bg-cloud p-4 text-sm leading-6 text-slate-700">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-pine text-xs font-bold text-white">
                    {index + 1}
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ol>
        </article>

        <form class="card" aria-label="合作咨询表单">
          <h2 class="text-xl font-bold text-ink">合作咨询表单</h2>
          <p class="mt-2 text-sm leading-6 text-slate-500">静态展示表单，暂不接后端。请添加微信或发送邮件沟通。</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <label class="text-sm font-medium text-ink">
              门店名称
              <input class="mt-2 w-full rounded-md border border-line px-3 py-3 text-sm outline-none focus:border-pine" placeholder="例如：某某中医馆" />
            </label>
            <label class="text-sm font-medium text-ink">
              行业类型
              <input class="mt-2 w-full rounded-md border border-line px-3 py-3 text-sm outline-none focus:border-pine" placeholder="例如：口腔 / 推拿 / 教培" />
            </label>
            <label class="text-sm font-medium text-ink">
              城市商圈
              <input class="mt-2 w-full rounded-md border border-line px-3 py-3 text-sm outline-none focus:border-pine" placeholder="例如：上海真如" />
            </label>
            <label class="text-sm font-medium text-ink">
              联系方式
              <input class="mt-2 w-full rounded-md border border-line px-3 py-3 text-sm outline-none focus:border-pine" placeholder="微信或邮箱" />
            </label>
            <label class="text-sm font-medium text-ink sm:col-span-2">
              当前问题
              <textarea class="mt-2 min-h-32 w-full rounded-md border border-line px-3 py-3 text-sm outline-none focus:border-pine" placeholder="例如：美团团单卖不动，小红书没有咨询，朋友圈不知道发什么"></textarea>
            </label>
          </div>
          <button
            type="button"
            class="mt-5 inline-flex min-h-11 items-center justify-center rounded-md bg-pine px-5 py-3 text-sm font-semibold text-white hover:bg-ink"
          >
            请添加微信或发送邮件
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
