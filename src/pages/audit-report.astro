---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import SectionHeading from '@components/SectionHeading.astro';
import OperationsDashboard from '@components/OperationsDashboard.astro';
import { auditReport } from '@data/auditReport';
---

<BaseLayout title="69元详细诊断报告" description="69元详细诊断报告，系统拆解本地门店美团页面、团单、评价、竞品和搜索词，24小时内交付PDF或Word。">
  <section class="bg-cloud section-pad">
    <div class="container-narrow grid items-center gap-10 lg:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="eyebrow">69元详细诊断报告</p>
        <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">{auditReport.subtitle}</h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">{auditReport.description}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <PrimaryButton href="/contact">添加微信咨询报告</PrimaryButton>
          <PrimaryButton href="/cases" variant="secondary">查看匿名案例</PrimaryButton>
        </div>
      </div>
      <OperationsDashboard />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="交付内容"
        title="不是泛泛建议，而是一份能执行的整改顺序"
        description="报告重点不是堆术语，而是让店主知道线上页面为什么漏客、先改哪里、怎么安排后续动作。"
      />
      <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
        <article class="card">
          <h2 class="text-xl font-bold text-ink">报告会看什么</h2>
          <ul class="mt-5 grid gap-3 sm:grid-cols-2">
            {
              auditReport.reportSections.map((item) => (
                <li class="rounded-md bg-cloud px-4 py-3 text-sm font-semibold text-slate-700">{item}</li>
              ))
            }
          </ul>
        </article>
        <article class="card">
          <h2 class="text-xl font-bold text-ink">你会拿到什么</h2>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {
              auditReport.deliverables.map((item) => (
                <div class="rounded-md border border-line px-4 py-3 text-sm font-semibold text-pine">{item}</div>
              ))
            }
          </div>
          <div class="mt-5 rounded-md bg-cloud p-4 text-sm leading-7 text-slate-600">
            4.9元门店基础体检更适合先做轻量判断；如果确认需要完整拆解，可抵扣69元详细诊断报告。
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="适合门店"
        title="更适合已经意识到线上页面有问题，但不知道先改哪里的店"
      />
      <div class="grid gap-5 md:grid-cols-2">
        <article class="card">
          <h2 class="text-xl font-bold text-ink">适合这些情况</h2>
          <ul class="mt-5 space-y-3">
            {
              auditReport.suitableFor.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-slate-600">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-pine"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>
        <article class="card">
          <h2 class="text-xl font-bold text-ink">开始前需要提供</h2>
          <ul class="mt-5 space-y-3">
            {
              auditReport.requiredInfo.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-slate-600">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-moss"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading eyebrow="报告样例" title="一份报告的大致结构" description="以下为匿名化结构样例，只展示目录和交付逻辑，不公开客户原始报告。" />
      <div class="rounded-lg border border-line bg-white p-5 shadow-sm sm:p-7">
        <div class="grid gap-4 md:grid-cols-4">
          {
            auditReport.reportSections.map((item, index) => (
              <div class="rounded-md bg-cloud p-4">
                <p class="text-xs font-semibold text-pine">0{index + 1}</p>
                <p class="mt-2 text-sm font-bold leading-6 text-ink">{item}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <SectionHeading eyebrow="FAQ" title="店主常问的问题" />
      <div class="grid gap-4 md:grid-cols-2">
        {
          auditReport.faqs.map((faq) => (
            <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
              <h2 class="text-base font-bold text-ink">{faq.question}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">{faq.answer}</p>
            </article>
          ))
        }
      </div>
      <div class="mt-10 rounded-lg bg-ink p-6 text-center text-white">
        <h2 class="text-2xl font-bold">想先看你的门店页面问题？</h2>
        <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-slate-300">
          发送门店链接、城市商圈和当前问题，先做初步判断，再确认是否需要69元详细诊断报告。
        </p>
        <div class="mt-6">
          <PrimaryButton href="/contact">联系合作 / 添加微信咨询</PrimaryButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
