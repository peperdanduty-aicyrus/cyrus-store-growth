---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/CTASection.astro';

const principles = ['先诊断，再执行', '先看链路，再看单点', '先讲清楚，再谈转化', '不刷单，不做虚假承诺', '医疗健康类内容坚持合规、克制、真实'];

const serviceModes = [
  {
    title: '初步体检',
    description: '快速判断页面、团单、评价或搜索入口中最明显的问题。'
  },
  {
    title: '深度报告',
    description: '系统拆解主图、页面、团单、竞品、搜索词和整改顺序。'
  },
  {
    title: '月度陪跑',
    description: '按周推进页面优化、内容策划、活动节奏和数据复盘。'
  },
  {
    title: '专项方案',
    description: '针对医疗健康、口腔、推拿、中医馆等行业做定制方案。'
  }
];
---

<BaseLayout
  title="关于我"
  description="Cyrus吕专注本地门店线上运营诊断与增长方案，重点关注美团点评、小红书、朋友圈、视频号和地图/AI搜索。"
  ogTitle="关于 Cyrus吕｜门店增长专家"
  ogDescription="我的工作方式：先诊断、看链路、重合规，帮助本地门店看清线上获客路径。"
>
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">我的工作方式</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">
        我不是帮门店多发几条内容，而是帮店主看清线上获客链路
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        我是 Cyrus吕，专注本地门店线上运营诊断与增长方案，重点关注美团点评、小红书、朋友圈、视频号、地图/AI搜索等本地获客入口。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="rounded-lg bg-ink p-6 text-white lg:p-8">
        <p class="eyebrow text-mint">为什么做这件事</p>
        <h2 class="mt-4 text-3xl font-bold tracking-normal">很多门店不是没有服务能力，而是线上讲不清楚</h2>
        <p class="mt-5 text-base leading-8 text-slate-300">
          店主花了钱做平台，却不知道问题到底出在曝光、点击、内容、咨询还是到店。我的工作是把平台展示、用户搜索、内容种草、咨询转化和到店复盘拆开看，再把最该先改的地方排出来。
        </p>
      </article>

      <article class="rounded-lg border border-line bg-white p-6 shadow-sm lg:p-8">
        <p class="eyebrow">工作原则</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            principles.map((item) => (
              <div class="rounded-md bg-cloud px-4 py-4 text-sm font-semibold text-ink">{item}</div>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <div class="mb-8 max-w-3xl">
        <p class="eyebrow">服务方式</p>
        <h2 class="mt-3 text-3xl font-bold tracking-normal text-ink">从一次判断，到持续优化</h2>
        <p class="mt-4 text-base leading-8 text-slate-600">
          不同门店的问题阶段不同，有的只需要先看基础问题，有的需要完整诊断，有的需要持续陪跑。服务会根据门店现状拆分，而不是一开始就套固定方案。
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          serviceModes.map((mode, index) => (
            <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold text-moss">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-bold text-ink">{mode.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{mode.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="开始诊断"
    title="先把你的门店线上问题拆清楚"
    description="发送门店名称、城市商圈、行业类型和平台链接，我会先判断最优先该看的位置。"
    primaryHref="/contact"
    primaryLabel="预约一次门店诊断"
    secondaryHref="/methodology"
    secondaryLabel="查看诊断方法论"
  />
</BaseLayout>
