---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
---

<BaseLayout title="关于我" description="我是 Cyrus吕，专注本地门店线上运营，帮助门店做好美团、小红书、朋友圈、视频号和本地搜索优化。">
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">关于我</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">我是 Cyrus吕，专注本地门店线上运营</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        主要帮助中医馆、推拿馆、口腔门诊、宠物医院、社区医美、综合门诊、健康驿站和教培托管等本地门店，做好美团、小红书、朋友圈、视频号和本地搜索优化。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="rounded-lg bg-ink p-6 text-white">
        <h2 class="text-2xl font-bold">服务风格</h2>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-slate-300">
          <li>说人话：把平台规则和运营动作翻译成老板能理解的话。</li>
          <li>看数据：关注曝光、浏览、咨询、到店和复盘，不凭感觉改页面。</li>
          <li>重落地：先解决最影响转化的问题，不做空泛方案。</li>
          <li>不做虚假承诺：不保证排名第一，不承诺固定咨询数量。</li>
        </ul>
      </aside>
      <div class="space-y-5">
        <article class="card">
          <h2 class="text-xl font-bold text-ink">我主要做什么</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            帮本地门店梳理线上获客链路，包括美团/大众点评页面、团单设计、小红书同城内容、朋友圈/视频号内容、本地搜索和AI搜索可见度资料优化。
          </p>
        </article>
        <article class="card">
          <h2 class="text-xl font-bold text-ink">我的服务方式</h2>
          <ol class="mt-4 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
            <li class="rounded-md bg-cloud p-4">1. 先诊断当前线上页面和账号</li>
            <li class="rounded-md bg-cloud p-4">2. 再输出问题清单和优化方案</li>
            <li class="rounded-md bg-cloud p-4">3. 确认后执行页面、内容和资料优化</li>
            <li class="rounded-md bg-cloud p-4">4. 定期复盘数据和下一步动作</li>
          </ol>
        </article>
        <PrimaryButton href="/contact">联系合作</PrimaryButton>
      </div>
    </div>
  </section>
</BaseLayout>
