---
import BaseLayout from '@layouts/BaseLayout.astro';
import CaseCard from '@components/CaseCard.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import CTASection from '@components/CTASection.astro';
import { cases } from '@data/cases';

const categories = ['全部', ...Array.from(new Set(cases.map((item) => item.category)))];
---

<BaseLayout
  title="案例复盘"
  description="案例不是成果包装，而是展示本地门店线上获客问题如何被拆解。"
>
  <section class="bg-ink section-pad text-white">
    <div class="container-narrow grid items-end gap-8 lg:grid-cols-[1fr_0.72fr]">
      <div>
        <p class="text-sm font-semibold text-emerald-200">案例复盘 / 问题拆解过程</p>
        <h1 class="mt-4 max-w-4xl text-4xl font-bold tracking-normal sm:text-5xl">
          案例不是成果包装，而是问题拆解过程
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-8 text-slate-300">
          以下案例均为匿名化或脱敏展示，只呈现行业问题、诊断思路和优化动作，不公开客户隐私和完整经营数据。对于未形成稳定数据的项目，只展示阶段目标和执行路径，不做夸大承诺。
        </p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/10 p-5">
        <p class="text-sm font-semibold text-white">案例页观看路径</p>
        <div class="mt-4 grid gap-3">
          <div class="rounded-md bg-white px-4 py-3 text-sm font-semibold text-ink">1. 核心问题：先判断卡点</div>
          <div class="rounded-md bg-white px-4 py-3 text-sm font-semibold text-ink">2. 诊断框架：再拆路径</div>
          <div class="rounded-md bg-white px-4 py-3 text-sm font-semibold text-ink">3. 优化动作：最后看交付</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="mx-auto mb-8 max-w-3xl text-center sm:mb-10">
        <p class="eyebrow mb-3">案例截图与报告预览</p>
        <h2 class="text-3xl font-bold tracking-normal text-ink sm:text-4xl">看诊断思路，也看实际交付材料</h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          每个案例按“合作初期、执行路径、成果转化”展开。报告已转为站内页面预览，点击图片可放大查看。
        </p>
      </div>

      <div class="sticky top-16 z-20 mb-6 overflow-x-auto border-y border-line bg-white/95 py-3 backdrop-blur">
        <div class="flex min-w-max gap-2">
          {
            categories.map((category, index) => (
              <button
                type="button"
                class={`case-filter rounded-full border px-4 py-2 text-sm font-semibold ${index === 0 ? 'border-pine bg-pine text-white' : 'border-line bg-white text-slate-600 hover:border-pine hover:text-pine'}`}
                data-filter={category}
              >
                {category}
              </button>
            ))
          }
        </div>
      </div>

      <div class="grid gap-8">
        {cases.map((item) => <CaseCard item={item} variant="detail" />)}
      </div>

      <div class="mt-10 rounded-lg bg-cloud p-6 text-center">
        <h2 class="text-xl font-bold text-ink">想知道你的门店线上页面哪里需要先改？</h2>
        <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-slate-600">
          可以发送门店名称、城市、平台链接和当前诉求，先做初步诊断。
        </p>
        <div class="mt-6">
          <PrimaryButton href="/contact">预约一次门店诊断</PrimaryButton>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

  <div id="case-lightbox" class="fixed inset-0 z-50 hidden bg-ink/90 p-4" aria-hidden="true">
    <div class="mx-auto flex h-full max-w-5xl flex-col">
      <div class="mb-3 flex items-center justify-between gap-3 text-white">
        <p id="case-lightbox-title" class="text-sm font-semibold">预览</p>
        <button type="button" id="case-lightbox-close" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-ink">关闭</button>
      </div>
      <div class="min-h-0 flex-1 overflow-auto rounded-lg bg-white p-3">
        <img id="case-lightbox-image" src="" alt="" class="mx-auto max-h-none w-full max-w-4xl object-contain" />
      </div>
    </div>
  </div>

  <script>
    const filterButtons = document.querySelectorAll('.case-filter');
    const caseCards = document.querySelectorAll('[data-case-card]');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        filterButtons.forEach((item) => {
          item.classList.remove('border-pine', 'bg-pine', 'text-white');
          item.classList.add('border-line', 'bg-white', 'text-slate-600');
        });
        button.classList.add('border-pine', 'bg-pine', 'text-white');
        button.classList.remove('border-line', 'bg-white', 'text-slate-600');

        caseCards.forEach((card) => {
          const match = filter === '全部' || card.getAttribute('data-category') === filter;
          card.classList.toggle('hidden', !match);
        });
      });
    });

    const lightbox = document.getElementById('case-lightbox');
    const lightboxImage = document.getElementById('case-lightbox-image');
    const lightboxTitle = document.getElementById('case-lightbox-title');
    const lightboxClose = document.getElementById('case-lightbox-close');

    document.querySelectorAll('[data-lightbox-src]').forEach((button) => {
      button.addEventListener('click', () => {
        const src = button.getAttribute('data-lightbox-src') || '';
        const title = button.getAttribute('data-lightbox-title') || '预览';
        if (!lightbox || !lightboxImage || !lightboxTitle) return;
        lightboxImage.setAttribute('src', src);
        lightboxImage.setAttribute('alt', title);
        lightboxTitle.textContent = title;
        lightbox.classList.remove('hidden');
        lightbox.setAttribute('aria-hidden', 'false');
      });
    });

    const closeLightbox = () => {
      if (!lightbox || !lightboxImage) return;
      lightbox.classList.add('hidden');
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImage.setAttribute('src', '');
    };

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeLightbox();
    });
  </script>
</BaseLayout>
