---
import BaseLayout from '@layouts/BaseLayout.astro';
import CaseCard from '@components/CaseCard.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { cases } from '@data/cases';
---

<BaseLayout title="案例复盘" description="匿名本地门店线上运营案例，包含行业背景、初始问题、交付内容和阶段变化。">
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">案例复盘</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">用打码案例看清诊断和执行过程</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        以下案例基于真实服务素材整理，均做匿名处理，不展示真实店名、头像、手机号、地址、订单号和客户隐私。重点展示诊断结构、交付内容和阶段变化。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading title="匿名案例拆解" description="每个案例都围绕真实经营问题展开，重点呈现问题、动作、交付和适合参考的门店类型。" />
      <div class="grid gap-5 lg:grid-cols-2">
        {cases.map((item) => <CaseCard item={item} />)}
      </div>
      <div class="mt-10 rounded-lg bg-cloud p-6 text-center">
        <h2 class="text-xl font-bold text-ink">想知道你的门店线上页面哪里需要先改？</h2>
        <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-slate-600">
          可以发送门店名称、城市、平台链接和当前诉求，先做初步诊断。
        </p>
        <div class="mt-6">
          <PrimaryButton href="/contact">联系合作</PrimaryButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
