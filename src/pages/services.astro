---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import ServiceMatrix from '@components/ServiceMatrix.astro';
import CTASection from '@components/CTASection.astro';
import { servicePath, serviceSystems, serviceMatrix } from '@data/consulting';
---

<BaseLayout
  title="服务体系"
  description="从线上诊断到执行陪跑，帮助本地门店建立可复盘的获客链路。"
>
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">服务体系</p>
      <h1 class="mt-4 text-4xl font-bold leading-tight tracking-normal text-ink sm:text-5xl">
        从线上诊断到执行陪跑，帮门店建立可复盘的获客链路
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        服务不是先问“要不要代运营”，而是先判断问题出在展示、搜索、内容、咨询还是到店承接，再决定该做体检、报告、陪跑还是专项方案。
      </p>
      <div class="mt-8">
        <PrimaryButton href="/contact">预约一次门店诊断</PrimaryButton>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="rounded-xl border border-line bg-white p-5 shadow-sm sm:p-7">
        <p class="eyebrow">服务路径</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {
            servicePath.map((step, index) => (
              <div class="rounded-lg bg-cloud p-4">
                <p class="text-xs font-semibold text-moss">0{index + 1}</p>
                <p class="mt-3 text-lg font-bold text-ink">{step}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <div class="mx-auto mb-8 max-w-3xl text-center">
        <p class="eyebrow mb-3">服务模块</p>
        <h2 class="text-3xl font-bold text-ink sm:text-4xl">每一项服务都围绕获客链路展开</h2>
      </div>
      <div class="grid gap-5">
        {
          serviceSystems.map((service) => (
            <article class="rounded-lg border border-line bg-white p-5 shadow-sm sm:p-7">
              <div class="grid gap-6 lg:grid-cols-[0.7fr_1.3fr]">
                <div>
                  <h2 class="text-2xl font-bold text-ink">{service.title}</h2>
                  <p class="mt-4 text-sm leading-7 text-slate-600">{service.description}</p>
                </div>
                <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                  {service.points.map((point) => <li class="rounded-md border border-line px-4 py-3 text-sm font-medium text-ink">{point}</li>)}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <ServiceMatrix />

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <div class="mx-auto mb-8 max-w-3xl text-center">
        <p class="eyebrow mb-3">服务产品表</p>
        <h2 class="text-3xl font-bold text-ink sm:text-4xl">三档常用合作方式</h2>
      </div>
      <div class="overflow-hidden rounded-lg border border-line bg-white shadow-sm">
        <div class="grid border-b border-line bg-ink px-5 py-4 text-sm font-semibold text-white md:grid-cols-4">
          <span>产品</span>
          <span>适合</span>
          <span>交付</span>
          <span>入口</span>
        </div>
        {
          serviceMatrix.slice(0, 3).map((item) => (
            <div class="grid gap-3 border-b border-line px-5 py-5 text-sm leading-7 md:grid-cols-4">
              <strong class="text-ink">{item.title}</strong>
              <span>{item.fit}</span>
              <span>{item.deliverable}</span>
              <a href={item.href} class="font-semibold text-pine hover:text-ink">{item.cta}</a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
