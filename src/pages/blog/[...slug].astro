---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section-pad">
    <div class="container-narrow max-w-3xl">
      <a href="/blog" class="text-sm font-semibold text-pine hover:text-ink">返回博客</a>
      <p class="mt-8 text-sm font-semibold text-moss">{post.data.category}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-normal text-ink sm:text-5xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">{post.data.description}</p>
      <time datetime={post.data.publishDate.toISOString()} class="mt-5 block text-sm text-slate-500">
        {post.data.publishDate.toLocaleDateString('zh-CN')}
      </time>
      <div class="prose prose-slate mt-10 max-w-none prose-headings:text-ink prose-a:text-pine">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
