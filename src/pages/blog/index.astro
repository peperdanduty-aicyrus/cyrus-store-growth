---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/CTASection.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const categories = ['平台诊断', '美团点评', '小红书本地运营', '医疗健康内容', '教培招生', '案例复盘', '老板经营认知'];
const getPostHref = (id: string) => `/blog/${id.replace(/\.md$/, '')}/`;
---

<BaseLayout
  title="本地门店线上运营洞察"
  description="写给本地门店店主看的线上运营洞察，覆盖平台诊断、美团点评、小红书本地运营、医疗健康内容和案例复盘。"
  ogTitle="本地门店线上运营洞察｜Cyrus吕"
  ogDescription="不是普通博客，而是围绕本地门店线上获客问题写的咨询笔记。"
>
  <section class="bg-cloud section-pad">
    <div class="container-narrow max-w-4xl">
      <p class="eyebrow">洞察</p>
      <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl">本地门店线上运营洞察</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        这里不写空泛概念。每篇文章都围绕一个具体问题：顾客为什么不点、为什么不问、为什么不信，以及店主可以先改哪里。
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <div class="mb-8 flex flex-wrap gap-2">
        {categories.map((category) => <span class="rounded-full bg-cloud px-3 py-2 text-xs font-semibold text-pine">{category}</span>)}
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <article class="flex h-full flex-col rounded-lg border border-line bg-white p-5 shadow-sm">
              <div class="flex flex-wrap gap-2 text-xs font-semibold">
                <span class="rounded-full bg-cloud px-3 py-1 text-moss">{post.data.category}</span>
                <span class="rounded-full bg-cloud px-3 py-1 text-slate-500">{post.data.readingTime}</span>
              </div>
              <h2 class="mt-4 text-xl font-bold leading-7 text-ink">
                <a href={getPostHref(post.id)} class="hover:text-pine">{post.data.title}</a>
              </h2>
              <p class="mt-3 text-xs font-semibold text-slate-500">适合：{post.data.industry}</p>
              <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{post.data.summary}</p>
              <a href={getPostHref(post.id)} class="mt-5 text-sm font-semibold text-pine hover:text-ink">阅读全文</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="从文章到门店"
    title="看完文章，仍然不知道自己店铺先改哪里？"
    description="把门店链接发来，我会从页面、团单、评价、搜索和内容承接几个角度帮你判断。"
    primaryHref="/contact"
    primaryLabel="预约一次门店诊断"
    secondaryHref="/methodology"
    secondaryLabel="查看诊断框架"
  />
</BaseLayout>
