---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import InsightCards from '@components/InsightCards.astro';
import DiagnosticFramework from '@components/DiagnosticFramework.astro';
import ServiceMatrix from '@components/ServiceMatrix.astro';
import IndustryScenarios from '@components/IndustryScenarios.astro';
import CasePreview from '@components/CasePreview.astro';
import CTASection from '@components/CTASection.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import { fitLists } from '@data/consulting';
import { cases } from '@data/cases';
import { site } from '@data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
).slice(0, 6);
const featuredCases = cases.filter((item) => ['oral-case', 'spa-case', 'tcm-case', 'tuina-diagnosis'].includes(item.id));
const getPostHref = (id: string) => `/blog/${id.replace(/\.md$/, '')}/`;
---

<BaseLayout
  title="本地门店线上运营诊断与增长方案"
  description={site.description}
  ogTitle="Cyrus吕｜本地门店线上运营诊断与增长方案"
  ogDescription={site.description}
>
  <HeroSection />
  <InsightCards />
  <DiagnosticFramework />
  <ServiceMatrix />

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <div class="mx-auto mb-8 max-w-3xl text-center">
        <p class="eyebrow mb-3">合作匹配</p>
        <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">我更适合帮助这类门店</h2>
      </div>
      <div class="grid gap-5 lg:grid-cols-2">
        <article class="rounded-lg border border-line bg-white p-5 shadow-sm sm:p-7">
          <h3 class="text-2xl font-bold text-ink">适合</h3>
          <ul class="mt-5 grid gap-3">
            {fitLists.good.map((item) => <li class="rounded-md bg-cloud px-4 py-3 text-sm leading-6 text-slate-700">{item}</li>)}
          </ul>
        </article>
        <article class="rounded-lg border border-line bg-white p-5 shadow-sm sm:p-7">
          <h3 class="text-2xl font-bold text-ink">不适合</h3>
          <ul class="mt-5 grid gap-3">
            {fitLists.bad.map((item) => <li class="rounded-md bg-cloud px-4 py-3 text-sm leading-6 text-slate-700">{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <IndustryScenarios />
  <CasePreview items={featuredCases} />

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <div class="mx-auto mb-8 max-w-3xl text-center">
        <p class="eyebrow mb-3">洞察文章</p>
        <h2 class="text-3xl font-bold leading-tight text-ink sm:text-4xl">给本地门店老板看的线上运营洞察</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <article class="flex h-full flex-col rounded-lg border border-line bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold text-moss">{post.data.category} / {post.data.industry}</p>
              <h3 class="mt-3 text-xl font-bold leading-snug text-ink">
                <a href={getPostHref(post.id)} class="hover:text-pine">{post.data.title}</a>
              </h3>
              <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{post.data.summary}</p>
              <div class="mt-5 flex items-center justify-between border-t border-line pt-4 text-xs text-slate-500">
                <span>{post.data.readingTime}</span>
                <PrimaryButton href={getPostHref(post.id)} variant="secondary">阅读</PrimaryButton>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
