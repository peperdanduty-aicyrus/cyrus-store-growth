---
import BaseLayout from '@layouts/BaseLayout.astro';
import PrimaryButton from '@components/PrimaryButton.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CaseCard from '@components/CaseCard.astro';
import ResourceCard from '@components/ResourceCard.astro';
import OperationsDashboard from '@components/OperationsDashboard.astro';
import { site, merchantTypes } from '@data/site';
import { services } from '@data/services';
import { cases } from '@data/cases';
import { resources } from '@data/resources';
import { offerCards, miniAuditDetails, painPoints, processSteps, reportDetails } from '@data/home';

const featuredCases = cases.slice(0, 4);
const featuredResources = resources.slice(0, 2);
---

<BaseLayout title="本地门店线上运营方案库" description={site.tagline}>
  <section class="bg-cloud section-pad">
    <div class="container-narrow grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="eyebrow">本地门店线上运营方案库</p>
        <h1 class="mt-4 text-4xl font-bold tracking-normal text-ink sm:text-5xl lg:text-6xl">
          {site.tagline}
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">{site.description}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <PrimaryButton href="/contact">联系合作 / 添加微信咨询</PrimaryButton>
          <PrimaryButton href="/audit-report" variant="secondary">查看199元报告内容</PrimaryButton>
        </div>
      </div>
      <aside>
        <OperationsDashboard />
        <div class="mt-4 rounded-lg border border-line bg-white p-5 shadow-soft">
        <p class="text-sm font-semibold text-pine">我能帮门店先看清楚这些问题</p>
        <ul class="mt-5 space-y-3">
          {
            painPoints.map((point) => (
              <li class="flex gap-3 text-sm leading-6 text-slate-700">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-moss"></span>
                <span>{point}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-6 rounded-md bg-cloud p-4 text-sm leading-6 text-slate-600">
          先把页面、内容、搜索渠道和承接流程拆清楚，帮助店主知道下一步该先改哪里。
        </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="服务选择"
        title="9.9元基础服务，199元完整诊断报告"
        description="如果只是想先了解线上页面基础问题，可以选择9.9元门店基础体检；如果需要系统拆解主图、页面、团单、评价、竞品和搜索词，可以选择199元完整诊断报告。"
      />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {
          offerCards.map((offer) => (
            <article class="card flex h-full flex-col">
              <p class="text-xs font-semibold text-moss">{offer.label}</p>
              <h3 class="mt-3 text-xl font-bold text-ink">{offer.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{offer.description}</p>
              <ul class="mt-5 space-y-2">
                {
                  offer.points.map((point) => (
                    <li class="flex gap-2 text-sm text-slate-600">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-pine"></span>
                      <span>{point}</span>
                    </li>
                  ))
                }
              </ul>
            </article>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <PrimaryButton href="/contact">咨询9.9元基础服务 / 199元报告</PrimaryButton>
      </div>
      <div class="mt-8 rounded-lg border border-line bg-cloud p-5 sm:p-6">
        <div class="mb-8 grid gap-6 rounded-lg bg-white p-5 sm:p-6 lg:grid-cols-[0.75fr_1.25fr]">
          <div>
            <p class="eyebrow">{miniAuditDetails.title}</p>
            <h3 class="mt-3 text-2xl font-bold text-ink">先做一次基础体检，判断页面是否存在明显漏客点</h3>
            <p class="mt-4 text-sm leading-7 text-slate-600">{miniAuditDetails.description}</p>
          </div>
          <div>
            <div class="grid gap-3 sm:grid-cols-3">
              {
                miniAuditDetails.delivery.map((item) => (
                  <div class="rounded-md bg-cloud px-4 py-3 text-sm font-semibold text-pine">{item}</div>
                ))
              }
            </div>
            <ul class="mt-5 grid gap-3 sm:grid-cols-2">
              {
                miniAuditDetails.items.map((item) => (
                  <li class="rounded-md border border-line px-4 py-3 text-sm text-slate-700">{item}</li>
                ))
              }
            </ul>
            <p class="mt-5 text-xs leading-6 text-slate-500">
              说明：{miniAuditDetails.boundaries.join('、')}。
            </p>
          </div>
        </div>
        <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
          <div>
            <p class="eyebrow">{reportDetails.title}</p>
            <h3 class="mt-3 text-2xl font-bold text-ink">系统拆解门店线上页面，明确优先整改顺序</h3>
            <p class="mt-4 text-sm leading-7 text-slate-600">{reportDetails.description}</p>
          </div>
          <div>
            <div class="grid gap-3 sm:grid-cols-3">
              {
                reportDetails.delivery.map((item) => (
                  <div class="rounded-md bg-white px-4 py-3 text-sm font-semibold text-pine">{item}</div>
                ))
              }
            </div>
            <ul class="mt-5 grid gap-3 sm:grid-cols-2">
              {
                reportDetails.items.map((item) => (
                  <li class="rounded-md border border-line bg-white px-4 py-3 text-sm text-slate-700">{item}</li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="服务概览"
        title="围绕门店线上获客链路做诊断、方案和执行"
        description="服务不是单个平台动作，而是从顾客看到你、理解你、咨询你，到最终到店的完整路径。"
      />
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="适合商家"
        title="更适合需要解释信任、项目和到店理由的本地门店"
        description="重点服务中医馆、推拿馆、口腔门诊，也可支持艾灸理疗馆、正骨馆、医美和综合门诊等健康类门店。"
      />
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          merchantTypes.map((type) => (
            <div class="rounded-lg border border-line bg-white px-4 py-5 text-center text-sm font-semibold text-ink">
              {type}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="案例参考"
        title="用真实经营问题的写法呈现案例"
        description="案例均做匿名处理，不展示真实店名，重点呈现诊断思路、优化动作和阶段目标。"
      />
      <div class="grid gap-5 md:grid-cols-2">
        {featuredCases.map((item) => <CaseCard item={item} />)}
      </div>
      <div class="mt-8 text-center">
        <PrimaryButton href="/cases" variant="secondary">查看全部案例</PrimaryButton>
      </div>
    </div>
  </section>

  <section class="bg-cloud section-pad">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="免费资料"
        title="先领取检查表，再判断是否需要深入诊断"
        description="资料适合店主自己先做一次基础自查。"
      />
      <div class="grid gap-5 md:grid-cols-2">
        {featuredResources.map((resource) => <ResourceCard resource={resource} />)}
      </div>
      <div class="mt-8 text-center">
        <PrimaryButton href="/resources" variant="secondary">查看全部资料</PrimaryButton>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow rounded-lg bg-ink px-5 py-10 text-white sm:px-8 lg:px-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr]">
        <div>
          <p class="text-sm font-semibold text-emerald-200">合作方式</p>
          <h2 class="mt-3 text-2xl font-bold tracking-normal sm:text-3xl">先诊断，再出方案，再执行优化，再复盘数据</h2>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
            我在沈阳，支持远程服务全国门店。合作前会先看门店现状和线上基础，再给出店主能看懂、能执行的优化建议。
          </p>
        </div>
        <ol class="grid gap-3">
          {
            processSteps.map((step, index) => (
              <li class="rounded-md bg-white/10 px-4 py-3 text-sm">
                {index + 1}. {step}
              </li>
            ))
          }
        </ol>
      </div>
      <div class="mt-8">
        <PrimaryButton href="/contact">联系合作</PrimaryButton>
      </div>
    </div>
  </section>
</BaseLayout>
